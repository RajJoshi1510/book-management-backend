<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Masterpiece</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* Force floating label up when there is a value pre-filled */
        .form-group input:not([value=""]):not(:focus)+label,
        .form-group textarea:not(:empty):not(:focus)+label {
            top: 0;
            font-size: 0.8rem;
            color: var(--primary);
            font-weight: 600;
            background: white;
        }
    </style>
</head>

<body>

    <!-- Mind-blowing Glassmorphism Navbar -->
    <nav class="navbar">
        <a href="/" class="nav-brand">
            <span class="material-icons-round">auto_stories</span>
            BookSphere
        </a>
        <ul class="nav-links">
            <li><a href="/">Explore</a></li>
            <li><a href="/manage-books">Manage Library</a></li>
        </ul>
    </nav>

    <div class="page-header" style="margin-bottom: 1rem;">
        <h1>Edit Record</h1>
    </div>

    <div class="form-container">
        <form action="/edit/<%= book.id %>" method="POST">
            <div class="form-group">
                <input type="text" name="title" id="title" value="<%= book.title %>" placeholder=" " required>
                <label for="title">Book Title</label>
            </div>

            <div class="form-group">
                <textarea name="description" id="description" rows="4" placeholder=" "
                    required><%= book.description %></textarea>
                <label for="description">Captivating Description</label>
            </div>

            <div class="form-group">
                <input type="url" name="image" id="image" value="<%= book.image %>" placeholder=" " required>
                <label for="image">Cover Image URL</label>
            </div>

            <div class="form-group">
                <input type="text" name="price" id="price" value="<%= book.price %>" placeholder=" " required>
                <label for="price">Price (₹)</label>
            </div>

            <div class="form-group">
                <input type="text" name="publish_date" id="publish_date" value="<%= book.publish_date %>"
                    placeholder=" " required>
                <label for="publish_date">Publish Date</label>
            </div>

            <div class="form-group">
                <input type="text" name="author" id="author" value="<%= book.author %>" placeholder=" " required>
                <label for="author">Author Name</label>
            </div>

            <button type="submit" class="btn btn-primary"
                style="width: 100%; justify-content: center; padding: 15px; font-size: 1.1rem; margin-top: 10px;">
                <span class="material-icons-round">save</span>
                Save Changes
            </button>
        </form>
    </div>

</body>

</html>