<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add A New Masterpiece</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <!-- Mind-blowing Glassmorphism Navbar -->
    <nav class="navbar">
        <a href="/" class="nav-brand">
            <span class="material-icons-round">auto_stories</span>
            BookSphere
        </a>
        <ul class="nav-links">
            <li><a href="/">Explore</a></li>
            <li><a href="/manage-books">Manage Library</a></li>
        </ul>
    </nav>

    <div class="page-header" style="margin-bottom: 1rem;">
        <h1>Add New Masterpiece</h1>
    </div>

    <div class="form-container">
        <form action="/add" method="POST">
            <div class="form-group">
                <input type="text" name="title" id="title" placeholder=" " required>
                <label for="title">Book Title</label>
            </div>

            <div class="form-group">
                <textarea name="description" id="description" rows="4" placeholder=" " required></textarea>
                <label for="description">Captivating Description</label>
            </div>

            <div class="form-group">
                <input type="url" name="image" id="image" placeholder=" " required>
                <label for="image">Cover Image URL</label>
            </div>

            <div class="form-group">
                <input type="number" step="0.01" name="price" id="price" placeholder=" " required>
                <label for="price">Price (₹)</label>
            </div>

            <div class="form-group">
                <input type="date" name="publish_date" id="publish_date" placeholder=" " required>
                <label for="publish_date">Publish Date</label>
            </div>

            <div class="form-group">
                <input type="text" name="author" id="author" placeholder=" " required>
                <label for="author">Author Name</label>
            </div>

            <button type="submit" class="btn btn-primary"
                style="width: 100%; justify-content: center; padding: 15px; font-size: 1.1rem; margin-top: 10px;">
                <span class="material-icons-round">publish</span>
                Publish to Store
            </button>
        </form>
    </div>

</body>

</html>